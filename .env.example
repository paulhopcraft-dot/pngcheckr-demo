# Copy this file to .env and fill in a real Postgres connection string.
#
# Option A — Docker Postgres (docker-compose.yml in this repo), if Docker Desktop
# is available and running:
#   DATABASE_URL=postgres://attestli:attestli@localhost:5433/attestli
#
# Option B — a native/local Postgres install (e.g. an existing Postgres service).
# Create the role + database once, then point at it:
#   CREATE ROLE attestli LOGIN PASSWORD 'attestli';
#   CREATE DATABASE attestli OWNER attestli;
#   DATABASE_URL=postgres://attestli:attestli@localhost:5432/attestli
#
# Render-managed Postgres: use the "Internal Database URL" from the Render dashboard.
DATABASE_URL=postgres://attestli:attestli@localhost:5432/attestli

# Port the Express server listens on (Render sets this automatically in production).
PORT=3001
